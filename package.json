{
    "name": "todo-api",
    "version": "1.0.0",
    "module": "src/index.js",
    "scripts": {
        "dev": "bun run --watch source/server.ts",
        "lint": "oxlint --fix",
        "fmt": "oxfmt --write",
        "prepare": "husky",
        "commit": "cz"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "drizzle-orm": "^0.45.2",
        "elysia": "latest",
        "postgres": "^3.4.8",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@paralleldrive/cuid2": "^3.3.0",
        "@types/bun": "latest",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "dotenv": "^17.4.0",
        "drizzle-kit": "^0.31.10",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.58.0"
    },
    "peerDependencies": {
        "typescript": "^6.0.2"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "oxlint --fix",
            "oxfmt"
        ]
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    }
}
